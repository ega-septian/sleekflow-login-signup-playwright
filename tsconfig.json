{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "playwright.config.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "test-data/**/*.ts",
    "tests/**/*.ts"
  ]
}
